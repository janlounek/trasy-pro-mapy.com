{
  "name": "mapy-for-chrome-backend",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "db:create": "wrangler d1 create mapy-for-chrome-db",
    "db:migrate:local": "wrangler d1 execute mapy-for-chrome-db --file=./schema.sql",
    "db:migrate:remote": "wrangler d1 execute mapy-for-chrome-db --remote --file=./schema.sql",
    "db:migrate:votes:local": "wrangler d1 execute mapy-for-chrome-db --file=./migrations/votes.sql",
    "db:migrate:votes:remote": "wrangler d1 execute mapy-for-chrome-db --remote --file=./migrations/votes.sql",
    "db:migrate:remove-pii:local": "wrangler d1 execute mapy-for-chrome-db --file=./migrations/remove_pii.sql",
    "db:migrate:remove-pii:remote": "wrangler d1 execute mapy-for-chrome-db --remote --file=./migrations/remove_pii.sql"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241112.0",
    "typescript": "^5.6.3",
    "wrangler": "^3.86.0"
  }
}
