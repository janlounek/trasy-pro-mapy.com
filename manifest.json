{
  "manifest_version": 3,
  "name": "Trasy pro mapy.com",
  "version": "0.1.0",
  "description": "Ukládejte a sdílejte vlastní turistické trasy přímo nad mapou na mapy.com.",
  "key": "",
  "permissions": ["identity", "storage", "unlimitedStorage", "alarms"],
  "host_permissions": [
    "https://api.mapy.com/*",
    "https://login.szn.cz/*",
    "https://*.mapy.com/*",
    "https://*.mapy.cz/*",
    "https://mapy-for-chrome-backend.trasypromapy.workers.dev/*"
  ],
  "background": {
    "service_worker": "src/background.ts",
    "type": "module"
  },
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "Trasy pro mapy.com"
  },
  "content_scripts": [
    {
      "matches": ["https://*.mapy.com/*", "https://*.mapy.cz/*"],
      "js": ["src/main-world.ts"],
      "world": "MAIN",
      "run_at": "document_start"
    },
    {
      "matches": ["https://*.mapy.com/*", "https://*.mapy.cz/*"],
      "js": ["src/content.ts"],
      "run_at": "document_idle"
    }
  ]
}
